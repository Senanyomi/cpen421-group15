# Production environment variables for Vercel deployment
# Set these in Vercel dashboard: Settings → Environment Variables

# Development (localhost) — used by 'npm run dev'
VITE_IDENTITY_URL=http://localhost:3001
VITE_INCIDENT_URL=http://localhost:3002
VITE_DISPATCH_URL=http://localhost:3003
VITE_ANALYTICS_URL=http://localhost:3004

# Production (Render) — replace with your actual Render service URLs
# # Format: https://SERVICE-NAME.onrender.com
# VITE_IDENTITY_URL=https://nerdcp-identity-service.onrender.com
# VITE_INCIDENT_URL=https://nerdcp-incident-service.onrender.com
# VITE_DISPATCH_URL=https://nerdcp-dispatch-service.onrender.com
# VITE_ANALYTICS_URL=https://nerdcp-analytics-service.onrender.com
