// Prisma schema — Dispatch Tracking Service

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Vehicle ──────────────────────────────────────────────────────────────────
model Vehicle {
  id          String        @id @default(uuid())
  callSign    String        @unique @map("call_sign")  // e.g. "FIRE-01", "AMB-07"
  type        VehicleType
  status      VehicleStatus @default(AVAILABLE)
  latitude    Float?                                   // current position (null = not yet reported)
  longitude   Float?
  lastUpdated DateTime?     @map("last_updated")       // when GPS was last received
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt      @map("updated_at")

  locationHistory LocationPing[]
  assignments     VehicleAssignment[]

  @@map("vehicles")
}

// ─── Location Ping ────────────────────────────────────────────────────────────
// Every GPS update is stored here — gives us a full movement trail per vehicle
model LocationPing {
  id          String   @id @default(uuid())
  vehicleId   String   @map("vehicle_id")
  latitude    Float
  longitude   Float
  speed       Float?                         // km/h — optional, sent by GPS device
  heading     Float?                         // degrees 0-360 — optional
  recordedAt  DateTime @default(now()) @map("recorded_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, recordedAt(sort: Desc)])  // fast history lookups
  @@map("location_pings")
}

// ─── Vehicle Assignment ───────────────────────────────────────────────────────
// Links a vehicle to an incident for the duration of the response
model VehicleAssignment {
  id           String           @id @default(uuid())
  vehicleId    String           @map("vehicle_id")
  incidentId   String           @map("incident_id")   // from Incident Service
  assignedBy   String           @map("assigned_by")   // userId from Identity Service
  status       AssignmentStatus @default(ACTIVE)
  assignedAt   DateTime         @default(now()) @map("assigned_at")
  completedAt  DateTime?        @map("completed_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([incidentId])
  @@index([vehicleId, status])
  @@map("vehicle_assignments")
}

// ─── Enums ────────────────────────────────────────────────────────────────────
enum VehicleType {
  AMBULANCE
  POLICE_CAR
  FIRE_TRUCK
  HAZMAT_UNIT
  RESCUE_TEAM
  COMMAND_UNIT
}

enum VehicleStatus {
  AVAILABLE    // ready to be dispatched
  DISPATCHED   // assigned and en route
  ON_SCENE     // arrived at incident
  RETURNING    // heading back to base
  OFFLINE      // out of service / maintenance
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}
