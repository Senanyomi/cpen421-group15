# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3003
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Create first: createdb nerdcp_dispatch
DATABASE_URL="postgresql://postgres:password@localhost:5432/nerdcp_dispatch?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must match the secret used in identity-service
JWT_ACCESS_SECRET="change-this-access-secret-in-production"

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL="amqp://localhost:5672"

# ─── GPS History Retention ────────────────────────────────────────────────────
# How many location pings to keep per vehicle (oldest are pruned automatically)
GPS_HISTORY_LIMIT=500
