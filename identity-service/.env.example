# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Create this DB first: createdb nerdcp_identity
DATABASE_URL="postgresql://postgres:password@localhost:5432/nerdcp_identity?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Access token: short-lived (used on every request)
JWT_ACCESS_SECRET="change-this-access-secret-in-production"
JWT_ACCESS_EXPIRES_IN="15m"

# Refresh token: long-lived (used only to get a new access token)
JWT_REFRESH_SECRET="change-this-refresh-secret-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL="amqp://localhost:5672"

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
