# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3004
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Create first: createdb nerdcp_analytics
DATABASE_URL="postgresql://postgres:password@localhost:5432/nerdcp_analytics?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must match the secret used in identity-service
JWT_ACCESS_SECRET="change-this-access-secret-in-production"

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL="amqp://localhost:5672"
