# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
# Create first: createdb nerdcp_incidents
DATABASE_URL="postgresql://postgres:password@localhost:5432/nerdcp_incidents?schema=public"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must match the secret used in identity-service — tokens are verified here too
JWT_ACCESS_SECRET="change-this-access-secret-in-production"

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_URL="amqp://localhost:5672"
